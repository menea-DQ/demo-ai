# --- Demo finance ---
# Segregazione su Redis: tutte le chiavi avranno prefisso "finance:"
APP_NAMESPACE=finance

# --- Sicurezza condivisa (@donq/security) ---
REDIS_URL=redis://localhost:6379
SESSION_SECRET=cambia-questo-con-un-segreto-lungo-e-casuale
SESSION_TTL_SEC=1800
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SEC=1800
DAILY_GLOBAL_BUDGET=500
MAX_CONCURRENT_SESSIONS=50

# --- Cloudflare Turnstile (obbligatorio in prod) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_CONTACT_URL=https://donq.io/contacts
