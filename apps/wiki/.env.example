# ============================================================
#  Aurora Wiki - configurazione
#  Copia questo file in .env.local e compila i valori.
# ============================================================

# --- OpenRouter (obbligatorio: build del wiki + risposte) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx
# Modello usato per le risposte e per la pipeline di costruzione del wiki
OPENROUTER_MODEL=google/gemini-2.5-flash
# (opzionale) modello diverso solo per il build del wiki
# OPENROUTER_BUILD_MODEL=google/gemini-2.5-flash
LLM_MAX_TOKENS=1024
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Redis (obbligatorio per i limiti di sicurezza) ---
# In sviluppo: `docker compose up -d` espone Redis su localhost:6379
REDIS_URL=redis://localhost:6379

# --- Sicurezza sessione ---
# Genera un valore casuale lungo, es: openssl rand -hex 32
SESSION_SECRET=cambia-questo-con-un-segreto-lungo-e-casuale
SESSION_TTL_SEC=1800

# --- Rate limit per utente ---
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SEC=1800

# --- Budget globale giornaliero (anti drain crediti) ---
# Numero massimo di domande/giorno su TUTTA l'app
DAILY_GLOBAL_BUDGET=500

# --- Sessioni concorrenti (anti flooding) ---
MAX_CONCURRENT_SESSIONS=50

# --- Input ---
MAX_QUESTION_LEN=600

# --- Cloudflare Turnstile (anti-bot) ---
# Lascia vuoti in sviluppo locale per disattivare la verifica.
# In PRODUZIONE compila entrambi: senza chiavi le sessioni vengono rifiutate.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- CTA (form contatti Donq) ---
NEXT_PUBLIC_CONTACT_URL=https://donq.io/contacts
